{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sova",
  "scopeName": "source.sova",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#libraries" },
    { "include": "#calls" },
    { "include": "#properties" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sova",
          "begin": "//",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.sova" } },
          "end": "$",
          "patterns": [{ "include": "#comment-tags" }]
        },
        {
          "name": "comment.block.sova",
          "begin": "/\\*",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.sova" } },
          "end": "\\*/",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.sova" } },
          "patterns": [{ "include": "#comment-tags" }]
        }
      ]
    },
    "comment-tags": {
      "patterns": [
        {
          "name": "keyword.other.documentation.sova",
          "match": "\\b(TODO|FIXME|NOTE|WARNING|HACK|BUG)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sova",
          "begin": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.sova" } },
          "end": "\"",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.sova" } },
          "patterns": [
            { "name": "constant.character.escape.sova", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.single.sova",
          "begin": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.sova" } },
          "end": "'",
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.sova" } },
          "patterns": [
            { "name": "constant.character.escape.sova", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.sova",
      "begin": "\\{",
      "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.sova" } },
      "end": "\\}",
      "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.sova" } },
      "patterns": [
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#libraries" },
        { "include": "#calls" },
        { "include": "#properties" },
        { "include": "#operators" },
        { "name": "variable.other.readwrite.sova", "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b" }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.sova",
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.sova" },
            "2": { "name": "entity.name.function.sova" }
          }
        },
        {
          "name": "meta.class.definition.sova",
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.class.sova" },
            "2": { "name": "entity.name.type.class.sova" }
          }
        },
        {
          "name": "meta.variable.declaration.sova",
          "match": "\\b(let)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.variable.sova" },
            "2": { "name": "variable.other.definition.sova" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.sova",
          "match": "\\b(if|elif|else)\\b"
        },
        {
          "name": "keyword.control.loop.sova",
          "match": "\\b(for|while|in|break|continue)\\b"
        },
        {
          "name": "keyword.control.flow.sova",
          "match": "\\b(return|try|catch|throw|shell)\\b"
        },
        {
          "name": "keyword.control.import.sova",
          "match": "\\b(import|from|as|export|default)\\b"
        },
        {
          "name": "storage.modifier.extends.sova",
          "match": "\\bextends\\b"
        },
        {
          "name": "storage.type.declaration.sova",
          "match": "\\b(let|function|class)\\b"
        },
        {
          "name": "keyword.operator.word.sova",
          "match": "\\b(and|or|not|is|in)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.sova",
          "match": "\\b(Int|Float|String|Bool|Null|List|Tuple|Object|Any|Function)\\b"
        },
        {
          "name": "entity.name.type.sova",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*[?<(])"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.sova",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.self.sova",
          "match": "\\bself\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sova",
          "match": "(?<![A-Za-z0-9_])\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.numeric.integer.sova",
          "match": "(?<![A-Za-z0-9_])\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?(?![A-Za-z0-9_])"
        }
      ]
    },
    "libraries": {
      "patterns": [
        {
          "name": "support.namespace.sova",
          "match": "\\bSova\\b"
        },
        {
          "name": "support.class.library.sova",
          "match": "(?<=Sova\\.)\\b(Math|Files|Json|Time|Random|Regex|Crypto|Csv|Path|Http|Statistics|Email|Database|VirtualFiles|Collections|Strings)\\b"
        },
        {
          "name": "support.function.builtin.sova",
          "match": "\\b(print|input|range|len|int|float|str|bool|type)\\b(?=\\s*\\()"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "meta.function-call.sova",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.call.sova" } }
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "meta.property-access.sova",
          "match": "(\\?\\.|\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.sova" },
            "2": { "name": "variable.other.property.sova" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sova",
          "match": "\\?\\.|\\?\\?|\\.\\.\\.|\\.\\.|\\*\\*|=>|->|\\+=|-=|\\*=|/=|==|!=|>=|<=|&&|\\|\\||[+\\-*/%=!<>?:]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.block.sova", "match": "[{}]" },
        { "name": "punctuation.section.group.sova", "match": "[()]" },
        { "name": "punctuation.section.brackets.sova", "match": "[\\[\\]]" },
        { "name": "punctuation.separator.sova", "match": "[,;.]" }
      ]
    }
  }
}
